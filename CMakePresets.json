{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "w64devkit",
      "displayName": "w64devkit (Windows GCC, static)",
      "description": "Windows build with the w64devkit GCC toolchain: statically linked SDL3, an x86-64-v2 instruction baseline, and the GUI (windows) subsystem.",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SHOGI_STATIC": "ON",
        "CMAKE_C_FLAGS": "-march=x86-64-v2",
        "CMAKE_CXX_FLAGS": "-march=x86-64-v2"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "w64devkit",
      "configurePreset": "w64devkit"
    }
  ]
}
