// shogi.rc - Windows resource script.  Generated by CMake from shogi.rc.in;
// edit the template, not the build-dir copy.  Icon 1 (the lowest id) becomes
// the application icon shown by Explorer and the taskbar.  shogi.ico is
// generated by tools/genicon.cpp.  VERSIONINFO populates the .exe's File
// version / Product version fields; the version comes from PROJECT_VERSION.
1 ICON "shogi.ico"

1 VERSIONINFO
FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,0,0
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,0,0
FILEFLAGSMASK  0x3FL
FILEFLAGS      0x0L
FILEOS         0x40004L      // VOS_NT_WINDOWS32
FILETYPE       0x1L          // VFT_APP
FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"     // en-US, Unicode
        BEGIN
            VALUE "FileDescription",  "Shogi"
            VALUE "FileVersion",      "@PROJECT_VERSION@"
            VALUE "InternalName",     "shogi"
            VALUE "OriginalFilename", "shogi.exe"
            VALUE "ProductName",      "Shogi"
            VALUE "ProductVersion",   "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 0x04B0
    END
END
